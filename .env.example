# rlwatch environment variables
# Copy this file to .env and fill in your values

# --- Slack Alerts ---
# Get a webhook URL from https://api.slack.com/messaging/webhooks
RLWATCH_SLACK_WEBHOOK_URL=
RLWATCH_SLACK_CHANNEL=

# --- Email Alerts ---
RLWATCH_SMTP_HOST=smtp.gmail.com
RLWATCH_SMTP_PORT=587
RLWATCH_SMTP_USER=
RLWATCH_SMTP_PASSWORD=
RLWATCH_EMAIL_FROM=
RLWATCH_EMAIL_TO=   # Comma-separated list of emails

# --- Run Configuration ---
RLWATCH_RUN_ID=     # Optional: set a fixed run ID
RLWATCH_LOG_DIR=./rlwatch_logs
